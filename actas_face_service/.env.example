NODE_ENV=development
PORT=4100

# Mismos valores que actas_backend/.env — comparte base de datos y validación de JWT.
DATABASE_URL=postgresql://actas:actas@db:5432/actas
JWT_SECRET=use-el-mismo-que-actas_backend

# Umbral de similitud coseno [0-1] para aceptar una verificación facial como coincidencia.
UMBRAL_SIMILITUD=0.65
